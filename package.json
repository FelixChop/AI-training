{
  "name": "@felixchop/focus",
  "version": "0.1.0",
  "description": "Local MCP server that turns any agentic AI tool into a personal chief of staff.",
  "license": "MIT",
  "author": "Félix Revert",
  "type": "module",
  "bin": {
    "focus": "dist/server.js"
  },
  "files": [
    "dist",
    "src/catalog",
    "src/templates",
    "src/instructions",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "SPEC.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "better-sqlite3": "^11.5.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "proper-lockfile": "^4.1.2",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/better-sqlite3": "^7.6.11",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.17.6",
    "@types/proper-lockfile": "^4.1.4",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/felixchop/focus"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "productivity",
    "todo",
    "chief-of-staff",
    "local-first"
  ]
}
